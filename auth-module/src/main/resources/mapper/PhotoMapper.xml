<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.demo.auth.mapper.PhotoMapper">



    <!-- Base Column List -->
    <sql id="Base_Column_List">
        file_name, file_path, file_size, file_type, file_url, type
    </sql>

    <!-- Result Map for FileEntity -->
    <resultMap id="FileEntityResultMap" type="com.demo.auth.entity.FileEntity">
        <id column="file_name" property="fileName" />
        <result column="file_path" property="filePath" />
        <result column="file_size" property="fileSize" />
        <result column="file_type" property="fileType" />
        <result column="file_url" property="fileUrl" />
        <result column="type" property="type" />
        <result column="upload_time" property="uploadTime" />
        <result column="original_file_name" property="originalFileName" />
        <result column="storage_type" property="storageType" />
    </resultMap>

    <select id="selectPhotosBytypes" resultMap="FileEntityResultMap">
        SELECT
        <include refid="Base_Column_List"/>
        FROM uploaded_files
        <where>
            <if test="types != null and types.size() > 0">
                AND type IN
                <foreach collection="types" item="singleType" open="(" separator="," close=")">
                    #{singleType}
                </foreach>
            </if>
        </where>
        ORDER BY type,upload_time DESC
    </select>

</mapper>
